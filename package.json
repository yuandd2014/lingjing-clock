{
  "name": "lingjing-clock",
  "version": "1.3.2",
  "description": "灵境时钟 (LingJing Clock) - Windows 桌面毛玻璃时钟, 搭载 Live2D 角色 / 天气 / 农历 / 日历 / 自动检查更新",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "dist": "electron-builder --win --x64 --publish never",
    "pack": "electron-builder --dir",
    "dist:linux": "electron-builder --linux deb AppImage --x64 --publish never"
  },
  "build": {
    "appId": "com.lingjing.clock",
    "productName": "LingJing Clock",
    "publish": {
      "provider": "github",
      "owner": "yuandd2014",
      "repo": "lingjing-clock",
      "releaseType": "release",
      "vPrefixedTagName": true
    },
    "directories": {
      "output": "dist_v18"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "splash.html",
      "LICENSE.txt",
      "css/**/*",
      "js/**/*",
      "assets/**/*",
      "!**/node_modules/@capacitor/**",
      "!**/node_modules/@fontsource/**",
      "!**/node_modules/pixi.js/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "license": "LICENSE.txt",
      "installerHeader": "build/installerHeader.bmp",
      "installerSidebar": "build/installerSidebar.bmp",
      "installerIcon": "build/installerIcon.ico",
      "installerHeaderIcon": "build/installerHeaderIcon.ico",
      "include": "build/installer.nsh",
      "deleteAppDataOnUninstall": false,
      "artifactName": "LingJing.Clock.Setup.${version}.${ext}"
    },
    "portable": {
      "artifactName": "LingJingClock-Portable.exe"
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/linux/icon-512.png",
      "category": "Utility",
      "desktop": {
        "Name": "灵境时钟",
        "Comment": "灵境时钟 — Linux 桌面毛玻璃时钟, 搭载 Live2D 角色 / 天气 / 农历",
        "Categories": "Utility;Clock;",
        "Keywords": "clock;weather;lunar;live2d;lingjing;",
        "StartupNotify": "true",
        "StartupWMClass": "lingjing-clock"
      },
      "artifactName": "LingJing.Clock.${version}.${ext}"
    },
    "deb": {
      "priority": "optional",
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libappindicator3-1"
      ],
      "recommends": [
        "libsecret-1-0"
      ],
      "fpm": [
        "--deb-no-default-config-files"
      ]
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.0"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^6.5.10"
  }
}
