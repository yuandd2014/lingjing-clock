{
  "name": "lingjing-clock",
  "version": "1.2.1",
  "description": "灵境时钟 (LingJing Clock) - Windows 桌面毛玻璃时钟, 搭载 Live2D 角色 / 天气 / 农历 / 日历 / 自动检查更新",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "dist": "electron-builder --win --x64",
    "pack": "electron-builder --dir"
  },
  "build": {
    "appId": "com.lingjing.clock",
    "productName": "LingJing Clock",
    "publish": {
      "provider": "github",
      "owner": "yuandd2014",
      "repo": "lingjing-clock",
      "releaseType": "release",
      "vPrefixedTagName": true
    },
    "directories": {
      "output": "dist_v11"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "splash.html",
      "LICENSE.txt",
      "css/**/*",
      "js/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "license": "LICENSE.txt",
      "installerHeader": "build/installerHeader.bmp",
      "installerSidebar": "build/installerSidebar.bmp",
      "installerIcon": "build/installerIcon.ico",
      "installerHeaderIcon": "build/installerHeaderIcon.ico",
      "include": "build/installer.nsh",
      "deleteAppDataOnUninstall": false,
      "artifactName": "LingJing.Clock.Setup.${version}.${ext}"
    },
    "portable": {
      "artifactName": "LingJingClock-Portable.exe"
    }
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.0"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "pixi-live2d-display": "^0.4.0",
    "pixi.js": "^6.5.10"
  }
}
